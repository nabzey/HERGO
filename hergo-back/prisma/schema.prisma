// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Modèle User
model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      Role     @default(VOYAGEUR)
  status    Status   @default(ACTIF)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  voyages       Voyage[]
  logements     Logement[]
  reservations  Reservation[]
  reviews       Review[]
  notifications Notification[]
  reclamations  Reclamation[]

  @@map("User")
}

// Énumérations
enum Role {
  VOYAGEUR
  HOTE
  ADMIN
}

enum Status {
  ACTIF
  SUSPENDU
  BANNI
}

// Modèle Voyage
model Voyage {
  id              Int      @id @default(autoincrement())
  idVoyageur      Int
  destination     String
  dateDebut       DateTime
  dateFin         DateTime
  nombrePersonnes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  voyageur User @relation(fields: [idVoyageur], references: [id])

  @@map("Voyage")
}

// Modèle Logement
model Logement {
  id             Int            @id @default(autoincrement())
  titre          String
  description    String
  prixJour       Float
  capacite       Int
  adresse        String
  ville          String
  pays           String
  longitude      Float?
  latitude       Float?
  statut         LogementStatus @default(PUBLIE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  idProprietaire Int

  // Relations
  proprietaire User          @relation(fields: [idProprietaire], references: [id])
  images       Image[]
  equipements  Equipement[]
  espaces      Espace[]
  reservations Reservation[]
  reviews      Review[]
  reclamations Reclamation[]

  @@map("Logement")
}

enum LogementStatus {
  PUBLIE
  BROUILLON
  EN_ATTENTE
  REJETE
}

// Modèle Image
model Image {
  id         Int      @id @default(autoincrement())
  url        String
  idLogement Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  logement Logement @relation(fields: [idLogement], references: [id])

  @@map("Image")
}

// Modèle Equipement
model Equipement {
  id         Int      @id @default(autoincrement())
  nom        String
  idLogement Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  logement Logement @relation(fields: [idLogement], references: [id])

  @@map("Equipement")
}

// Modèle Espace
model Espace {
  id          Int      @id @default(autoincrement())
  nom         String
  description String
  idLogement  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  logement Logement @relation(fields: [idLogement], references: [id])

  @@map("Espace")
}

// Modèle Reservation
model Reservation {
  id              Int               @id @default(autoincrement())
  idVoyageur      Int
  idLogement      Int
  dateDebut       DateTime
  dateFin         DateTime
  nombrePersonnes Int
  prixTotal       Float
  statut          ReservationStatus @default(EN_ATTENTE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  voyageur User      @relation(fields: [idVoyageur], references: [id])
  logement Logement  @relation(fields: [idLogement], references: [id])
  payments Payment[]

  @@map("Reservation")
}

enum ReservationStatus {
  EN_ATTENTE
  CONFIRME
  ANNULE
  TERMINE
}

// Modèle Review
model Review {
  id          Int      @id @default(autoincrement())
  idVoyageur  Int
  idLogement  Int
  note        Int      @default(5)
  commentaire String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  voyageur User     @relation(fields: [idVoyageur], references: [id])
  logement Logement @relation(fields: [idLogement], references: [id])

  @@map("Review")
}

// Modèle Notification
model Notification {
  id        Int              @id @default(autoincrement())
  idUser    Int
  message   String
  type      NotificationType
  lu        Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user User @relation(fields: [idUser], references: [id])

  @@map("Notification")
}

enum NotificationType {
  RESERVATION
  MESSAGE
  SYSTEM
  PAIEMENT
}

// Modèle Reclamation
model Reclamation {
  id          Int               @id @default(autoincrement())
  idVoyageur  Int
  idLogement  Int
  sujet       String
  description String
  statut      ReclamationStatus @default(EN_ATTENTE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  voyageur User     @relation(fields: [idVoyageur], references: [id])
  logement Logement @relation(fields: [idLogement], references: [id])

  @@map("Reclamation")
}

enum ReclamationStatus {
  EN_ATTENTE
  EN_TRAITEMENT
  RESOLU
  REJETE
}

// Modèle Payment
model Payment {
  id              Int           @id @default(autoincrement())
  idReservation   Int
  stripePaymentId String?
  amount          Float
  currency        String        @default("eur")
  status          PaymentStatus @default(EN_ATTENTE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  reservation Reservation @relation(fields: [idReservation], references: [id])

  @@map("Payment")
}

enum PaymentStatus {
  EN_ATTENTE
  CONFIRME
  ECHOUE
  REMBOURSE
}
